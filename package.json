{
  "name": "@matthewenderle/vue-classification-banner",
  "version": "0.1.0",
  "description": "A reusable Vue 3 and Nuxt classification banner component with configurable text, colors, and project-wide defaults.",
  "type": "module",
  "license": "MIT",
  "author": "Matthew Enderle",
  "homepage": "https://github.com/mattenderle488/vue-classification-banner#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattenderle488/vue-classification-banner.git"
  },
  "bugs": {
    "url": "https://github.com/mattenderle488/vue-classification-banner/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "classification",
    "classification-banner",
    "cui",
    "banner",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css",
    "**/*.vue"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./nuxt": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "vue-tsc --noEmit",
    "build:module": "nuxt build-module",
    "build:lib": "vite build",
    "build": "npm run clean && npm run build:module && npm run build:lib",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.0.0",
    "@nuxt/module-builder": "^1.0.2",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "nuxt": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}